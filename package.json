{
  "name": "reporte-cartera",
  "version": "1.0.0",
  "private": true,
  "main": "Electron/main.js",
  "scripts": {
    "dev": "cd Frontend && vite",
    "build": "cd Frontend && vite build",
    "electron": "electron .",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.0.0",
    "electron": "^26.0.0",
    "electron-builder": "^24.6.0",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.reporte.cartera",
    "productName": "Reporte Cartera",
    "compression": "maximum",
    "asar": true,
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "Frontend/dist/**/*",
      "Electron/**/*",
      "Backend/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
